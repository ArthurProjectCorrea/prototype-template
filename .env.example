
# Supabase Configuration
# Get these values from your Supabase project settings at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application URL for email confirmation links and redirects
# Used when sending confirmation emails for email changes and sign-ups
# Must be the exact URL where your app is hosted
NEXT_PUBLIC_APP_URL=http://localhost:3000
